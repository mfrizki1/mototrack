{
  "name": "mototrack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/bot.js",
    "dev": "tsx watch src/bot.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "grammy": "^1.43.0",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
